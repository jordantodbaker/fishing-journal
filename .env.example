# Neon serverless Postgres connection string. Use the pooled URL for app traffic
# and the direct URL for migrations. Both are listed in your Neon project console.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-west-2.aws.neon.tech/fishing_journal?sslmode=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-west-2.aws.neon.tech/fishing_journal?sslmode=require"

# Clerk authentication. Get these from https://dashboard.clerk.com.
# The publishable key is exposed to the client; the secret key must stay server-only.
VITE_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional: customize Clerk routes if you change the default sign-in/up paths.
# CLERK_SIGN_IN_URL="/sign-in"
# CLERK_SIGN_UP_URL="/sign-up"
